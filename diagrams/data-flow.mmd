  %% --- Type system feeds everything ---
  TS -.-> DATA

  %% --- Locale files feed composable ---
  EN --> USE_LANG
  KO --> USE_LANG
  MS --> USE_LANG
  JA --> USE_LANG
  USE_LANG <--> LS

  %% --- Composable → View connections ---
  USE_LANG --> HOME & MEMBERS_V & MEMBER_D & MUSIC_V & RELEASE_D & LIVE_V & AWARDS_V & BAWIGE_V & ABOUT_V
  USE_HEAD --> HOME & MEMBERS_V & MUSIC_V & RELEASE_D & LIVE_V & AWARDS_V & BAWIGE_V & ABOUT_V
  USE_MEMBER_COLOR --> MEMBER_D
  USE_SCROLL --> HOME
  USE_GLITCH --> HOME
  USE_AUDIO --> HOME

  %% --- Data → View connections ---
  MEMBERS_DATA --> MEMBERS_V & MEMBER_D & HOME
  RELEASES_DATA --> MUSIC_V & RELEASE_D & HOME
  SHOWS_DATA --> LIVE_V & HOME
  AWARDS_DATA --> AWARDS_V
  TIMELINE_DATA --> ABOUT_V
  FANDOM_DATA --> BAWIGE_V

  %% --- External CDN → Views ---
  ITUNES --> MUSIC_V & RELEASE_D & HOME
  YOUTUBE --> MUSIC_V & RELEASE_D

  %% --- Route params ---
  ROUTE_PARAMS(("Route Params<br/>:slug")) --> MEMBER_D & RELEASE_D

