flowchart LR
  subgraph DATA["Data Layer (src/data/)"]
    MEMBERS_DATA["members.ts<br/>members[], getMemberBySlug()"]
    RELEASES_DATA["releases.ts<br/>releases[], releasesSorted[],<br/>getReleaseBySlug(),<br/>getLatestRelease(), coverUrl()"]
    SHOWS_DATA["shows.ts<br/>shows[], upcomingShows[],<br/>pastShows[], worldTourShows[],<br/>getNextShow()"]
    AWARDS_DATA["awards.ts<br/>awards[], awardsSorted[]"]
    TIMELINE_DATA["timeline.ts<br/>timeline[], timelineSorted[]"]
    FANDOM_DATA["fandom.ts<br/>fandom: FandomData"]
  end

  subgraph TYPES["Type Definitions (src/types/)"]
    TS["index.ts<br/>Locale, LocalizedString,<br/>Member, Release, Show,<br/>Award, TimelineItem,<br/>FandomData"]
  end

  subgraph LOCALES["Locale Files (src/locales/)"]
    EN["en.json"]
    KO["ko.json"]
    MS["ms.json"]
    JA["ja.json"]
  end

  subgraph COMPOSABLES["Composables (src/composables/)"]
    USE_LANG["useLanguage<br/>t(), localized(),<br/>currentLocale, setLocale()"]
    USE_HEAD["useHead<br/>document.title, meta"]
    USE_MEMBER_COLOR["useMemberColor<br/>color, cssVars"]
    USE_SCROLL["useScrollReveal<br/>GSAP scroll animations"]
    USE_AUDIO["useAudioPlayer<br/>play(), pause(), seek()"]
    USE_GLITCH["useGlitch<br/>GSAP glitch text effect"]
  end

  subgraph VIEWS["Views"]
    HOME["HomeView"]
    MEMBERS_V["MembersView"]
    MEMBER_D["MemberDetailView"]
    MUSIC_V["MusicView"]
    RELEASE_D["ReleaseDetailView"]
    LIVE_V["LiveView"]
    AWARDS_V["AwardsView"]
    BAWIGE_V["BawigeView"]
    ABOUT_V["AboutView"]
  end

  subgraph EXTERNAL["External CDN"]
    ITUNES["iTunes CDN<br/>is1-ssl.mzstatic.com<br/>Album artwork"]
    YOUTUBE["YouTube CDN<br/>img.youtube.com<br/>Video thumbnails"]
  end

  subgraph STORAGE["Browser Storage"]
    LS["localStorage<br/>locale preference"]
